{
  "uid": "tunnel-engine",
  "title": "Tunnel Engine",
  "tags": [
    "vllm",
    "tunnel"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests running / waiting",
      "datasource": {
        "type": "prometheus",
        "uid": "tunnel-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 8
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "tunnel-prom"
          },
          "expr": "vllm:num_requests_running",
          "legendFormat": "{{instance_id}} running",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "tunnel-prom"
          },
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "{{instance_id}} waiting",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "KV cache usage",
      "datasource": {
        "type": "prometheus",
        "uid": "tunnel-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "fillOpacity": 8
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "tunnel-prom"
          },
          "expr": "vllm:kv_cache_usage_perc",
          "legendFormat": "{{instance_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "TTFT (p50 / p95 / p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "tunnel-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 8
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "tunnel-prom"
          },
          "expr": "histogram_quantile(0.5, sum by (le, instance_id) (rate(vllm:time_to_first_token_seconds_bucket[1m])))",
          "legendFormat": "{{instance_id}} p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "tunnel-prom"
          },
          "expr": "histogram_quantile(0.95, sum by (le, instance_id) (rate(vllm:time_to_first_token_seconds_bucket[1m])))",
          "legendFormat": "{{instance_id}} p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "tunnel-prom"
          },
          "expr": "histogram_quantile(0.99, sum by (le, instance_id) (rate(vllm:time_to_first_token_seconds_bucket[1m])))",
          "legendFormat": "{{instance_id}} p99",
          "refId": "C"
        }
      ]
    },
