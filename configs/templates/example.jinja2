{# Custom chat template example — copy and modify for per-service output shaping.
   Activate in models.yaml: chat_template: configs/templates/your-template.jinja2 #}

{%- for message in messages %}
  {%- if message['role'] == 'system' %}
<|system|>
{{ message['content'] | trim }}
<|end|>
  {%- elif message['role'] == 'user' %}
<|user|>
{{ message['content'] | trim }}
<|end|>
  {%- elif message['role'] == 'assistant' %}
<|assistant|>
{{ message['content'] | trim }}
<|end|>
  {%- endif %}
{%- endfor %}
{%- if add_generation_prompt %}
<|assistant|>
{%- endif %}
