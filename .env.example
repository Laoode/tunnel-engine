# Copy to .env — never commit .env

# HuggingFace token (required for gated models)
HF_TOKEN=hf_...

# LiteLLM gateway auth key. models.yaml references this via
# "os.environ/LITELLM_MASTER_KEY" — the secret lives here, never in a config.
# Dev: any local string is fine. Prod: generate a strong key and inject it via
# the container env / secret manager, NOT this file. e.g. openssl rand -hex 32
LITELLM_MASTER_KEY=sk-tunnel-dev-local-only

# Postgres for LiteLLM virtual keys / spend tracking (only if the registry
# defines services:). `make db-up` starts a local Docker Postgres on :5433
# using PG_PASSWORD; DATABASE_URL must match it. Any Postgres works (e.g. a
# managed free tier) as long as DATABASE_URL points at it.
PG_PASSWORD=change-me
DATABASE_URL=postgresql://litellm:change-me@localhost:5433/litellm

# LMCache Redis (only if an instance sets lmcache.backend=redis). Host/port
# become the RESP L2 adapter of that instance's `lmcache server` at launch
# time. Leave HOST empty to keep the local L1 (CPU RAM) tier only.
LMCACHE_REDIS_HOST=localhost
LMCACHE_REDIS_PORT=6379

# S3-compatible object storage (only if an instance uses an s3:// model with
# load_format: runai_streamer). Works with any S3 API.
AWS_ACCESS_KEY_ID=your_key_id
AWS_SECRET_ACCESS_KEY=your_application_key
AWS_ENDPOINT_URL=https://s3.ap-southeast-1.wasabisys.com
RUNAI_STREAMER_S3_ENDPOINT=https://s3.ap-southeast-1.wasabisys.com
AWS_EC2_METADATA_DISABLED=true              # skip the EC2 IMDS probe off-AWS
RUNAI_STREAMER_S3_USE_VIRTUAL_ADDRESSING=0  # path-style URLs (required for B2)

# DeepSeek API (only if configs use a remote_models entry pointing at DeepSeek).
# Referenced from models.yaml via api_key_env: DEEPSEEK_API_KEY.
DEEPSEEK_API_KEY=sk-...

# Pin GPU visibility for multi-GPU setups
CUDA_VISIBLE_DEVICES=0,1

# Logging
TUNNEL_LOG_LEVEL=INFO      # DEBUG, INFO, WARNING, ERROR
TUNNEL_LOG_FORMAT=console  # console, json
